server {
    server_name {{ env.Getenv "REMS_DOMAIN" }};
    include includes/ssl.conf;

    # this is the internal Docker DNS, cache for 60s
    resolver 127.0.0.11 valid=60s;

    location / {
        set $rems_domain rems-app;
	    proxy_pass http://$rems_domain:3000;
    	proxy_set_header Host $host;
    }
}

