server {
  server_name {{ env.Getenv "BACKOFFICE_DOMAIN" }};
  include includes/ssl.conf;

  location / {
    proxy_pass http://adele-backoffice-frontend:80;
  }
}

server {
  server_name {{ env.Getenv "BACKOFFICE_API_DOMAIN" }};
  include includes/ssl.conf;

  location / {
    proxy_pass http://adele-backoffice-backend:8081;
    # File ingestion drives the asynchronous SDA pipeline and can take
    # several minutes; allow long-running requests instead of 504-ing.
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
  }
}

