server {
  server_name {{ env.Getenv "WEB_DOMAIN" }}; 

  include includes/ssl.conf;  

  location / {
    proxy_pass http://adele-website-frontend:80; 
  }
}

server {
  server_name {{ env.Getenv "WEB_API_DOMAIN" }}; 
  include includes/ssl.conf;

  location / {
    proxy_pass http://adele-website-backend:8080; 
  }
}
