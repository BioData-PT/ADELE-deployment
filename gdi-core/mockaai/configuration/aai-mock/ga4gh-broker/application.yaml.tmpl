---

spring:
  main:
    allow-bean-definition-overriding: true
  mvc:
    pathmatch:
      matching-strategy: ant_path_matcher

logging:
  level:
    root: info
    cz.muni.ics: debug

mock-broker:
  enabled: True
  issuer: http://localhost:8080/oidc/
  jku: http://localhost:8080/ga4gh-broker/jwk
  path-to-jwk-file: /etc/lsaai-mock/keys.jwks
  visa-configs-path: /etc/lsaai-mock/ga4gh-broker/users/
#  passport-repositories: []
# Sample configuration for repository
  # passport-repositories:
  #   - name: REMS-LOCAL-API
  #     url: http://rems_app/api/permissions/{user_id}
  #     jwks: http://rems_app/api/jwk
  #     headers:
  #       - header: x-rems-api-key
  #         value: reporter-key
  #       - header: x-rems-user-id
  #         value: reporter-user

  passport-repositories:
    - name: REMS-LOCAL-API
      url: https://{{ env.Getenv "REMS_DOMAIN" }}/api/permissions/{user_id}
      jwks: https://{{ env.Getenv "REMS_DOMAIN" }}/api/jwk
      headers:
        - header: x-rems-api-key
          value: {{ env.Getenv "REPORTER_API_KEY" }}
        - header: x-rems-user-id
          value: {{ env.Getenv "REPORTER_USER" }}

visa-writers:
  enabled: False
# Uncomment to enable writing from visa sources
#  enabled: True
#  db:
#    url: jdbc:mysql://localhost:3307/broker
#    username: brokerUser
#    password: brokerPass
#    driver: "com.mysql.cj.jdbc.Driver"
#  repositories:
#    - name: Local REMS
#      jwks: http://rems.local/api/jwk
#      auth:
#        api-key:
#          api-key-header: X-visa-writer
#          api-key-value: X-vis-writer-key

passport-v1-0:
  enabled: True
  auth:
    - username: "broker-aai-user"
      password: "broker-aai-pass"

passport-v1-2:
  enabled: False
# Uncomment to enable token-exchange integration with AAI mock
