client-name: "Demo TRE Website, Backoffice and Storage"
# client-id: "metadados-tre"
# client-secret: "esparguete"
client-id: "{{ env.Getenv "CLIENT_ID"}}"
client-secret: "{{ env.Getenv "CLIENT_SECRET"}}"
#redirect-uris: ["http://localhost:9009/oidc-redirect"]
redirect-uris: ["http://localhost:8080/oidc-callback", 
  "https://{{ env.Getenv "WEB_DOMAIN" }}/oidc-callback",
  "https://{{ env.Getenv "WEB_API_DOMAIN" }}/oidc-callback",
  "https://{{ env.Getenv "BACKOFFICE_DOMAIN" }}/oidc-callback",
  "https://{{ env.Getenv "BACKOFFICE_API_DOMAIN" }}/oidc-callback",
  "https://{{ env.Getenv "STORAGE_AUTH_DOMAIN" }}/oidc/login"
]
token-endpoint-auth-method: "client_secret_basic"
scope: ["openid", "profile", "email", "ga4gh_passport_v1", "eduperson_entitlement"]
grant-types: ["authorization_code"]
post-logout-redirect-uris: ["http://localhost:9009/post-logout"]
